# Auth: pick one. Subscription is the default and draws on your Claude plan's usage
# allowance (no per-token charge). Get the token once with `claude setup-token`, then
# store it in your vault.
CLAUDE_CODE_OAUTH_TOKEN=

# API billing instead of the subscription. Requires funds on platform.claude.com.
# Vanguard injects only one of these into the sandbox; the OAuth token takes priority.
ANTHROPIC_API_KEY=

# z.ai GLM Coding Plan (https://z.ai). Select with --provider zai: the Claude Code CLI is pointed
# at z.ai's Anthropic-compatible coding endpoint (https://api.z.ai/api/coding/paas/v4), so NO
# Anthropic token is required when using zai. Under --llm-proxy the key is held by the sidecar.
ZAI_API_KEY=

# Log level: trace, debug, info, warn, error
VANGUARD_LOG_LEVEL=info

# Linear task source (or run `linear auth login`)
LINEAR_API_KEY=

# GitHub: PAT for the gh CLI (GitHub source, opening PRs, git push). Or use `gh auth login` locally.
GH_TOKEN=

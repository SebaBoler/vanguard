# Auth: pick one. Subscription is the default and draws on your Claude plan credits.
# Get the token once with `claude setup-token`, then store it in your vault.
CLAUDE_CODE_OAUTH_TOKEN=

# API billing instead of the subscription. Requires funds on platform.claude.com.
# Vanguard injects only one of these into the sandbox; the OAuth token takes priority.
ANTHROPIC_API_KEY=

# Log level: trace, debug, info, warn, error
VANGUARD_LOG_LEVEL=info

# Phase 2 Linear task source
LINEAR_API_KEY=

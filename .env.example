# Klucz API Anthropic — wymagany do uruchomienia agenta Claude Code w sandboxie.
# Przekazywany do sandboxa przez SandboxConfig.forwardEnv (plik env 0600, nie argv).
ANTHROPIC_API_KEY=

# Poziom logowania: trace | debug | info | warn | error
VANGUARD_LOG_LEVEL=info

# Faza 2 — Linear Task Fetcher
LINEAR_API_KEY=
